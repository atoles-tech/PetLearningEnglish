<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="credentials-changelog" author="atoles">
        <createTable tableName="credentials">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="username" type="VARCHAR(70)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="hash_password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="role" type="VARCHAR(10)">
            </column>
            
        </createTable>
    </changeSet>

    <changeSet id="credentials-changelog-add-created_at-column" author="atoles">
        <addColumn tableName="credentials">
            <column name="created_at" type="TIMESTAMP">
                
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>